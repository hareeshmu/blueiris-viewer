# Copy to `.env` and fill in your values. `.env` is gitignored.
# Used by scripts/deploy.sh to push prefs to devices.

BI_USER=admin
BI_PASS=changeme
BI_HOST=10.0.0.10
BI_PORT=81

# Default stream path if not passed on the command line (e.g. G for group mosaic).
BI_DEFAULT_PATH=G

# Optional: default reconnect delay in seconds and auto-start-on-boot flag.
RECONNECT_SECONDS=3
AUTOSTART=true
